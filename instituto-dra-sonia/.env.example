# ── Supabase ────────────────────────────────────────────────
# Encontre em: https://supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin ────────────────────────────────────────────────────
# Senha do painel administrativo (padrão: sonia2024)
ADMIN_PASSWORD=sonia2024

# ── API n8n (opcional) ───────────────────────────────────────
# Se definida, o endpoint POST /api/agendamentos exige o header:
#   x-api-key: VALOR_DESTA_CHAVE
# Se não definida, o endpoint fica aberto (útil para testes locais)
N8N_API_KEY=

# ── Servidor ────────────────────────────────────────────────
PORT=3000
